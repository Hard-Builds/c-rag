ENV=local
LOG_LEVEL=DEBUG

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=c_rag
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# CORS (comma-separated origins)
CORS_ALLOWED_URL=http://localhost:3000,http://localhost:8000

#Gemini LLM config
GEMINI_API_KEY=""
GEMINI_MODEL=""
GEMINI_EMBEDDING_MODEL=""
GEMINI_IMAGE_MODEL=""

#LangSmith Config
LANGSMITH_PROJECT=""
LANGSMITH_API_KEY=""
LANGSMITH_TRACING=true

# Internal service auth
INTERNAL_TOKEN=changeme